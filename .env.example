# ── Required ──────────────────────────────────────────────────────────────────
# Minimum needed to boot the dev server. Everything else is optional.
PUBLIC_PB_PORT=8090

# ── Dev Superuser (optional) ─────────────────────────────────────────────────
# When set, seeds this superuser on `task dev` and uses it for `task typegen`.
# Leave blank (or omit) to skip superuser seeding and type generation.
PB_SUPERUSER_EMAIL=
PB_SUPERUSER_PASSWORD=

# ── Discord Bot (optional) ────────────────────────────────────────────────────
# Server runs fine without these — you'll see a warning log and bot features
# will be disabled. Set both to enable the bot.
DISCORD_BOT_TOKEN=
DISCORD_DEV_GUILD_ID=

# ── OAuth2 Providers (optional) ───────────────────────────────────────────────
# Leave both fields blank to disable a provider. Set ID + secret to enable.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

PATREON_CLIENT_ID=
PATREON_CLIENT_SECRET=

INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
