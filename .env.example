# ── Required ──────────────────────────────────────────────────────────────────
# Minimum needed to boot the dev server. Everything else is optional.
PUBLIC_PB_PORT=8090

# ── Dev Superuser (optional) ─────────────────────────────────────────────────
# When set, seeds this superuser on `task dev` and uses it for `task typegen`.
# Leave blank (or omit) to skip superuser seeding and type generation.
PB_SUPERUSER_EMAIL=
PB_SUPERUSER_PASSWORD=

# ── Discord Bot (optional) ────────────────────────────────────────────────────
# Server runs fine without these — you'll see a warning log and bot features
# will be disabled. Set both to enable the bot.
DISCORD_BOT_TOKEN=
DISCORD_DEV_GUILD_ID=

# ── OAuth2 Providers (optional) ───────────────────────────────────────────────
# Leave both fields blank to disable a provider. Set ID + secret to enable.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

PATREON_CLIENT_ID=
PATREON_CLIENT_SECRET=

INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=

# ── Containers (optional) ─────────────────────────────────────────────────────
# Set CONTAINERS_ENABLED=true to expose /api/admin/containers/* and start the
# socket-discovery watcher. Requires rooted Podman + KVM/DRI passthrough +
# `_default.qcow2` baseline at $CONTAINERS_SHARED_DIR/hdds/. See CLAUDE.md.
CONTAINERS_ENABLED=false
CONTAINERS_SOCKET_DIR=./containers/xemu/qmp
CONTAINERS_SHARED_DIR=./containers/xemu/shared
CONTAINERS_INIT_DIR=./containers/xemu/init
CONTAINERS_CONFIGS_DIR=./containers/xemu/configs
CONTAINERS_BROWSER_DIR=./containers/browser
CONTAINERS_BROWSER_INIT_DIR=./containers/browser/init
CONTAINERS_PORT_BASE=3100
CONTAINERS_PORT_STRIDE=10
CONTAINERS_HOST_IP=localhost

# How the server invokes podman. Default "podman" runs rootless under the
# server user — fine for `podman create`, but `podman start` will fail on
# device passthrough (KVM/DRI/NET_ADMIN). Set to "sudo -n podman" to escalate;
# requires a passwordless sudoers rule. See CLAUDE.md "Containers".
#
# `--runtime=crun` is required: with the default OCI runtime on some hosts
# (runc 1.4.x), the jlesage/firefox kiosk's Xvnc rejects all X clients with
# "Authorization required, but no authorization protocol specified" and the
# noVNC view stays black. crun handles the same image cleanly. Install via
# `sudo pacman -S crun` (or distro equivalent).
CONTAINERS_PODMAN_CMD=sudo -n podman --runtime=crun

# Selkies streaming defaults (passed to xemu container as -e flags)
CONTAINERS_ENCODER=x264enc
CONTAINERS_FRAMERATE=60
CONTAINERS_CRF=20
CONTAINERS_WIDTH=960
CONTAINERS_HEIGHT=720
CONTAINERS_PIXELFLUX_WAYLAND=true
CONTAINERS_DRINODE=/dev/dri/renderD128
CONTAINERS_SHM_SIZE=1g
CONTAINERS_BROWSER_SHM_SIZE=2gb
